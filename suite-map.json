{
  "suite": {
    "short_name": "BGS",
    "long_name": "Boundary Governance Suite",
    "version": "0.1",
    "status": "draft coordination layer"
  },
  "naming": {
    "canonical_short_name": "BGS",
    "canonical_long_name": "Boundary Governance Suite",
    "suite_layer_term": "BGS",
    "axis_model_term": "BISS",
    "member_repo_term": "member repo",
    "member_framework_term": "member framework",
    "rigor_overlay_terms": ["Basic", "RIG"]
  },
  "entry_points": {
    "human": [
      "./SUITE.md",
      "./BGS-NAMING.md",
      "./BGS-GLOSSARY.md",
      "./ONBOARDING.md",
      "./SUITE-MAP.md",
      "./BGS-VERSIONING.md",
      "./BGS-FREEZE.yaml",
      "./BGS-COMPLIANCE.md",
      "../ucc/governance/BISS.txt",
      "../uic/contract-semantics/UIC.txt",
      "../ucc/execution-semantics/UCC-EXECUTION.txt",
      "../tic/SPEC.md",
      "./AI-RISK-CONTROL-MAP.md",
      "./GAPS.md"
    ],
    "machine": [
      "./suite-map.json",
      "./BGS-NAMING.md",
      "./BGS-GLOSSARY.md",
      "./ONBOARDING.md",
      "./BGS-VERSIONING.md",
      "./BGS-FREEZE.yaml",
      "./BGS-COMPLIANCE.md",
      "./AI-RISK-CONTROL-MAP.md",
      "./GAPS.md"
    ]
  },
  "onboarding": {
    "read_first": [
      "./README.md",
      "./SUITE-MAP.md",
      "./STATUS.md",
      "./BGS-COMPLIANCE.md",
      "./example-claims/README.md"
    ],
    "core_concepts": {
      "suite": "BGS",
      "member_frameworks": ["BISS", "GIC", "GCC", "Basic", "RIG", "UIC", "UCC", "ASM", "TIC"],
      "member_repos": ["../ucc/", "../uic/", "../asm/", "../tic/"],
      "hosting_rule": "suite membership is semantic; repo membership is physical"
    },
    "use_cases": {
      "BISS": "classifies boundary interactions",
      "GIC_GCC": "provide the semantic foundation",
      "UIC": "governs preflight decisions before execution",
      "UCC": "governs declaration-driven execution and convergence",
      "ASM": "governs formal state modeling, composition, and allowed transitions",
      "TIC": "verifies governed behavior with explicit tests and oracles",
      "Basic_RIG": "orthogonal rigor overlays"
    },
    "adoption_shapes": [
      "BISS -> UCC",
      "BISS -> UIC -> UCC",
      "BISS -> UCC -> TIC",
      "BISS -> UIC -> UCC -> TIC",
      "ASM",
      "ASM -> UCC",
      "ASM -> UIC -> UCC"
    ],
    "suite_docs_by_role": {
      "README.md": "entry point and navigation",
      "SUITE.md": "suite semantics and composition rules",
      "SUITE-MAP.md": "canonical matrix, hosting map, and split policy",
      "STATUS.md": "stable versus draft snapshot",
      "BGS-VERSIONING.md": "immutable refs and compatibility rules",
      "BGS-COMPLIANCE.md": "claim rules and example adoption claims",
      "AI-RISK-CONTROL-MAP.md": "direct governance scope and external controls",
      "example-claims/README.md": "canonical claim bundle"
    }
  },
  "active_prepublic_freeze": "./BGS-FREEZE.yaml",
  "repo_hosting": [
    {
      "repo": "../ucc/",
      "hosts": ["BISS", "GIC", "GCC", "Basic", "RIG", "UCC"]
    },
    {
      "repo": "../uic/",
      "hosts": ["UIC"]
    },
    {
      "repo": "../asm/",
      "hosts": ["ASM"]
    },
    {
      "repo": "../tic/",
      "hosts": ["TIC"]
    }
  ],
  "members": [
    {
      "id": "biss",
      "name": "BISS",
      "kind": "axis_model",
      "standalone": true,
      "semantic_base": [],
      "composition_with": ["gic", "gcc", "basic", "rig", "uic", "ucc", "tic"],
      "primary_use": "Classify interaction type and separate contract type from rigor grade.",
      "maturity": {
        "level": "foundation",
        "note": "Architectural frame for the suite."
      },
      "authoritative_docs": [
        "../ucc/governance/BISS.txt"
      ]
    },
    {
      "id": "gic",
      "name": "GIC",
      "kind": "interaction_foundation",
      "standalone": true,
      "semantic_base": [],
      "composition_with": ["gcc", "uic", "ucc"],
      "primary_use": "Define observable interaction semantics.",
      "maturity": {
        "level": "foundation",
        "note": "Base interaction layer."
      },
      "authoritative_docs": [
        "../ucc/contract-semantics/GIC.txt"
      ]
    },
    {
      "id": "gcc",
      "name": "GCC",
      "kind": "contract_foundation",
      "standalone": true,
      "semantic_base": ["gic"],
      "composition_with": ["uic", "ucc"],
      "primary_use": "Define explicit contract structure and closed result discipline.",
      "maturity": {
        "level": "foundation",
        "note": "Semantic floor below UIC and UCC."
      },
      "authoritative_docs": [
        "../ucc/contract-semantics/GCC.txt"
      ]
    },
    {
      "id": "basic",
      "name": "Basic",
      "kind": "rigor_grade",
      "standalone": true,
      "semantic_base": [],
      "composition_with": ["gic", "gcc", "uic", "ucc", "tic", "rig"],
      "primary_use": "Signal minimal implementation rigor.",
      "maturity": {
        "level": "foundation",
        "note": "Orthogonal rigor overlay."
      },
      "authoritative_docs": [
        "../ucc/governance/BASIC.txt"
      ]
    },
    {
      "id": "rig",
      "name": "RIG",
      "kind": "rigor_grade",
      "standalone": true,
      "semantic_base": [],
      "composition_with": ["gic", "gcc", "uic", "ucc", "tic", "basic"],
      "primary_use": "Signal stronger implementation rigor and observability discipline.",
      "maturity": {
        "level": "foundation",
        "note": "Orthogonal rigor overlay."
      },
      "authoritative_docs": [
        "../ucc/governance/RIG.txt"
      ]
    },
    {
      "id": "uic",
      "name": "UIC",
      "kind": "operational_contract",
      "standalone": true,
      "semantic_base": ["gic", "gcc"],
      "composition_with": ["ucc", "tic", "biss", "basic", "rig"],
      "ordered_before": ["ucc"],
      "primary_use": "Govern preflight decisions, gates, preferences, policies, and approvals before execution.",
      "maturity": {
        "level": "draft",
        "note": "Useful when governed preflight is needed."
      },
      "authoritative_docs": [
        "../uic/contract-semantics/UIC.txt",
        "../uic/guidance/UIC-PREFLIGHT.txt"
      ]
    },
    {
      "id": "ucc",
      "name": "UCC",
      "kind": "operational_contract",
      "standalone": true,
      "semantic_base": ["gic", "gcc"],
      "composition_with": ["uic", "tic", "biss", "basic", "rig"],
      "receives_from": ["uic"],
      "verified_by": ["tic"],
      "primary_use": "Govern declaration-driven execution and convergence with explicit results.",
      "maturity": {
        "level": "strong_operational_baseline",
        "note": "Strongest current operational baseline in the suite."
      },
      "authoritative_docs": [
        "../ucc/execution-semantics/UCC-EXECUTION.txt"
      ]
    },
    {
      "id": "tic",
      "name": "TIC",
      "kind": "verification_contract",
      "standalone": true,
      "semantic_base": [],
      "composition_with": ["uic", "ucc", "biss", "basic", "rig"],
      "verifies": ["uic", "ucc"],
      "primary_use": "Define tests, explicit oracles, diagnostics, and traceability.",
      "maturity": {
        "level": "specified_partial_integration",
        "note": "Specified and useful, but suite-wide compliance integration is partial."
      },
      "authoritative_docs": [
        "../tic/SPEC.md"
      ]
    },
    {
      "id": "asm",
      "name": "ASM",
      "kind": "state_model",
      "standalone": true,
      "semantic_base": [],
      "composition_with": ["ucc", "uic", "tic", "biss", "basic", "rig"],
      "primary_use": "Define formal state modeling, composition, coherence, and allowed transitions.",
      "maturity": {
        "level": "new_member",
        "note": "New generic state-model framework."
      },
      "authoritative_docs": [
        "../asm/README.md"
      ]
    }
  ],
  "adoption_profiles": [
    {
      "id": "classification_only",
      "members": ["biss"],
      "description": "Use BISS as the classification lens only."
    },
    {
      "id": "contract_foundation",
      "members": ["gic", "gcc"],
      "description": "Use the interaction and contract foundations without operational layers."
    },
    {
      "id": "minimal_governed_convergence",
      "members": ["biss", "ucc"],
      "description": "Minimal governed convergence."
    },
    {
      "id": "governed_execution",
      "members": ["biss", "uic", "ucc"],
      "description": "Governed preflight and governed execution."
    },
    {
      "id": "verified_execution",
      "members": ["biss", "ucc", "tic"],
      "description": "Governed execution with explicit verification."
    },
    {
      "id": "governed_and_verified_execution",
      "members": ["biss", "uic", "ucc", "tic"],
      "description": "Governed preflight, governed execution, and explicit verification."
    }
  ],
  "orthogonal_overlays": [
    {
      "members": ["basic", "rig"],
      "applies_to": ["gic", "gcc", "uic", "ucc", "tic"],
      "description": "Rigor overlays do not change interaction type."
    }
  ],
  "recommended_adoption_order": [
    "biss",
    "ucc",
    "tic",
    "uic",
    "basic_or_rig_overlay"
  ]
}
